      "parameters": {
        "jsCode": "const pgRow = Array.isArray($json) ? $json[0] : $json;\nconst webhook = $('Webhook Hoko').first().json.body;\n\nif (!pgRow || !pgRow.hoko_order_id) {\n  // No se encontró pedido en BD — no es de la tienda\n  return [];\n}\n\nreturn {\n  hoko_order_id: pgRow.hoko_order_id,\n  shopify_order_id: pgRow.pedido_id,\n  last_state: Number(webhook.last_state),\n  guide_number: webhook.number,\n  guide_id: webhook.guide_id,\n  tracking_url: `https://hoko.com.co/tracking/${webhook.number}`,\n  customer_name: webhook.customer_name\n};"
      },
