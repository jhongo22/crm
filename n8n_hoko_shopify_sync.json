        "jsonBody": "={{ (function(){\n  const fid = $json.data?.order?.fulfillments?.[0]?.id;\n  return JSON.stringify({\n    query: \"mutation fulfillmentEventCreate($fulfillmentEvent: FulfillmentEventInput!) {\\n  fulfillmentEventCreate(fulfillmentEvent: $fulfillmentEvent) {\\n    fulfillmentEvent { id status }\\n    userErrors { field message }\\n  }\\n}\",\n    variables: {\n      fulfillmentEvent: {\n        fulfillmentId: fid,\n        status: \"OUT_FOR_DELIVERY\",\n        message: \"Paquete en reparto - Hoko\",\n        notifyCustomer: true\n      }\n    }\n  });\n})() }}",
