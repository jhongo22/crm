        "jsonBody": "={\n  \"query\": \"query($id: ID!) {\\n  order(id: $id) {\\n    id\\n    name\\n    displayFinancialStatus\\n    displayFulfillmentStatus\\n    tags\\n    fulfillmentOrders(first: 10) {\\n      edges {\\n        node {\\n          id\\n          status\\n          requestStatus\\n          lineItems(first: 20) {\\n            edges {\\n              node {\\n                id\\n                lineItem { id name }\\n                remainingQuantity\\n              }\\n            }\\n          }\\n        }\\n      }\\n    }\\n    fulfillments(first: 5) {\\n      id\\n      status\\n      trackingInfo {\\n        number\\n        url\\n        company\\n      }\\n    }\\n  }\\n}\",\n  \"variables\": {\n    \"id\": \"gid://shopify/Order/{{ $json.shopify_order_id }}\"\n  }\n}",
        "options": {}
