        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ (function(){\n  const currentTags = $json.data?.order?.tags || [];\n  const tagsArr = Array.isArray(currentTags) ? currentTags : String(currentTags).split(',').map(t => t.trim());\n  if (!tagsArr.includes('novedad-hoko')) tagsArr.push('novedad-hoko');\n  const guide = $('Preparar datos').first().json;\n  return JSON.stringify({\n    query: \"mutation orderUpdate($input: OrderInput!) {\\n  orderUpdate(input: $input) {\\n    order { id tags }\\n    userErrors { field message }\\n  }\\n}\",\n    variables: {\n      input: {\n        id: \"gid://shopify/Order/\" + guide.shopify_order_id,\n        tags: tagsArr.join(',')\n      }\n    }\n  });\n})() }}",
